# 自动检测文本文件并进行行尾转换
* text=auto

# 指定 Windows 批处理文件使用 CRLF 行尾
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 纯英文文件使用 LF 行尾
README.md text eol=lf
LICENSE text eol=lf

# 纯中文文件使用 LF 行尾
README_CN.md text eol=lf

# 二进制文件不进行行尾转换
*.bin binary
*.elf binary
*.map binary
*.o binary
*.a binary
*.gz binary
*.zip binary
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary

# IDF 生成的压缩 OTA 文件
*.compressed binary
